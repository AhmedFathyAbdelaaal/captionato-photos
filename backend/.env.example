# ── Database ──
DATABASE_URL=postgresql://photos:photos@localhost:5432/captionato_photos

# ── Auth / JWT ──
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
# Initial admin, seeded on first boot only.
ADMIN_USERNAME=capcap
ADMIN_PASSWORD=changeme

# ── Image storage (map a persistent volume here in Coolify) ──
PHOTOS_ORIGINAL_PATH=/data/photos/originals
PHOTOS_THUMB_PATH=/data/photos/thumbs

# ── CORS — comma-separated allowed origins ──
ALLOWED_ORIGINS=https://photos.captionato.tech,http://localhost:4200
